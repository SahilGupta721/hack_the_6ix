# INNSIGHT environment template
# Copy relevant sections to api/.env and web/.env.local. Never commit real values.

# --- api/.env ---
# MongoDB Atlas connection string (Cowork provisions, human pastes)
MONGODB_URI=
# Google AI Studio key for Gemini memo generation + Nano Banana renders
GEMINI_API_KEY=
# Electricity Maps free tier (optional; cited fallback constant used when empty)
ELECTRICITYMAPS_API_KEY=

# --- web/.env.local ---
# Auth0 Regular Web App (Cowork provisions, human pastes)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
# ElevenLabs conversational agent (MLH promo)
ELEVENLABS_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# --- feature flags (default off; demo path must pass with all off) ---
NEXT_PUBLIC_FLAG_STAY22=false
NEXT_PUBLIC_FLAG_AUTH0=false
NEXT_PUBLIC_FLAG_RENDERS=false
NEXT_PUBLIC_FLAG_VOICE=false
NEXT_PUBLIC_FLAG_PIXEL=false

# --- api base url used by the web app ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
